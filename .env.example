# OpenClaw VPS Configuration (for local development)
# Copy this file to .env and fill in your values

# VPS SSH Access
server=YOUR_VPS_IP
user=root
password=YOUR_SSH_PASSWORD

# Slack Tokens (from your Slack app settings)
appToken=xapp-1-YOUR_APP_TOKEN_HERE
botUserToken=xoxb-YOUR_BOT_TOKEN_HERE

# Optional: Gateway settings
gatewayPort=18789
gatewayToken=YOUR_GATEWAY_AUTH_TOKEN
